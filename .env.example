# Astro Rattan (Astro Rattan) — Environment Variables

# Database (PostgreSQL — required in production)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Auth (REQUIRED in production — app crashes if missing)
JWT_SECRET=change-this-to-a-random-secret-in-production

# Ports (local dev only)
BACKEND_PORT=8028
FRONTEND_PORT=5198

# AI Provider — set ONE of these (Gemini is FREE, recommended for testing)
AI_PROVIDER=auto
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# CORS
CORS_ORIGINS=http://localhost:5198,https://astrorattan.com

# Email (Resend API — required for OTP and password reset)
RESEND_API_KEY=re_xxxxxxxx

# Swiss Ephemeris (optional — uses Moshier algorithm if empty)
EPHE_PATH=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Frontend (set in production .env)
# VITE_API_URL=https://astrorattan.com/api
