# AstroVedic — Environment Variables
DB_PATH=astrovedic.db
JWT_SECRET=change-this-to-a-random-secret-in-production
BACKEND_PORT=8028
FRONTEND_PORT=5198

# AI Provider — set ONE of these (Gemini is FREE, recommended for testing)
AI_PROVIDER=auto
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
CORS_ORIGINS=http://localhost:5198,http://localhost:5199

# WhatsApp Business API
WHATSAPP_TOKEN=your-whatsapp-business-api-token
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=astrovedic_verify_2026

EPHE_PATH=
RATE_LIMIT_PER_MINUTE=60

# SMTP / Email (optional — if not set, emails are logged and skipped)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
EMAIL_TO=

# Alternate SMTP aliases also supported
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
