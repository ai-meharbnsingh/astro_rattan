  "Mercury": {"prishta": 7,  "pratyak": 9},
  "Jupiter": {"prishta": 6,  "pratyak": 8},
  "Venus":   {"prishta": 5,  "pratyak": 7},
  "Saturn":  {"prishta": 8,  "pratyak": 2},
  "Rahu":    {"prishta": 8,  "pratyak": 2},
  "Ketu":    {"prishta": 3,  "pratyak": 1}
